# 确保 NX 引擎在初始化时能扫描到 MOM_end_of_group 事件，从而触发它。
# 这是解决 NX 漏发组结束事件的关键占位符。
if { ![llength [info commands MOM_end_of_group]] } {
    proc MOM_end_of_group { } {
        # 这是一个占位符，真正的逻辑在 PB_CMD_init_smart_grouping 中被拦截和重写
    }
}

